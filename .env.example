# ────────────────────────────────────────────────────────────────────────
# Vercel-side (Next.js app)
# ────────────────────────────────────────────────────────────────────────

# Neon Postgres (EU / Frankfurt)
DATABASE_URL=postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/kestklar

# Clerk
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Cloudflare R2 (jurisdiction: eu)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=kestklar-uploads
R2_ENDPOINT=https://xxx.eu.r2.cloudflarestorage.com
R2_PUBLIC_URL_PREFIX=

# Cloudflare API (used by Vercel API routes to enqueue Workflow runs)
CF_ACCOUNT_ID=xxx
CF_API_TOKEN=xxx
CF_QUEUE_PARSE_UPLOADS=parse-uploads

# Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xxx
TURNSTILE_SECRET_KEY=0xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STANDARD=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Email
LOOPS_API_KEY=xxx

# Observability
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ────────────────────────────────────────────────────────────────────────
# Worker-side (set via `wrangler secret put`, NOT in this file at runtime)
# Keys are listed here for the .env.example contract only.
# ────────────────────────────────────────────────────────────────────────
# OEKB_USER_AGENT="kestklar-bot/0.1 (+https://kestklar.at)"
# DATABASE_URL is provided via Hyperdrive binding in wrangler.toml

# ────────────────────────────────────────────────────────────────────────
# Local-dev only
# ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
