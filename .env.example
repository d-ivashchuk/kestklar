# ────────────────────────────────────────────────────────────────────────
# Required for local + production
# ────────────────────────────────────────────────────────────────────────

# Neon Postgres (EU / Frankfurt). Free tier is enough for the closed beta.
DATABASE_URL=postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/kestklar?sslmode=require

# Clerk — get from https://dashboard.clerk.com (free tier)
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# ────────────────────────────────────────────────────────────────────────
# Optional during beta — set to enable webhooks
# ────────────────────────────────────────────────────────────────────────

# Clerk webhook (keeps email in DB in sync). Without this, email stays NULL —
# the app still works because we don't depend on email for the tax flow.
CLERK_WEBHOOK_SECRET=whsec_xxx

# ────────────────────────────────────────────────────────────────────────
# Disabled during beta — leave blank
# ────────────────────────────────────────────────────────────────────────

# Stripe (we default every beta user to PRO, so this is unused)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PRO=

# Cloudflare R2 / Queues / Worker — the closed-beta upload path parses
# synchronously on Vercel; these only matter once we move parsing to Workers.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_QUEUE_PARSE_UPLOADS_ID=

# Turnstile (waitlist + sensitive forms — wire in once beta opens up)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email (transactional)
LOOPS_API_KEY=

# Observability
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# App URL — used in Stripe success/cancel URLs and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
